{
  "buildCommand": "cd artifacts/imperial-enterprise && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/imperial-enterprise/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/web-hosting/index", "destination": "/hosting", "statusCode": 301 },
    { "source": "/web-hosting/:path*", "destination": "/hosting", "statusCode": 301 },
    { "source": "/cloudhosting", "destination": "/hosting", "statusCode": 301 },
    { "source": "/domain-registration/:path*", "destination": "/domains", "statusCode": 301 },
    { "source": "/digital-certificate", "destination": "/services", "statusCode": 301 },
    { "source": "/business-email", "destination": "/services", "statusCode": 301 },
    { "source": "/titan-business-email-hosting", "destination": "/services", "statusCode": 301 },
    { "source": "/combo-offers", "destination": "/services", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}